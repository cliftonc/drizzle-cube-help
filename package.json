{
  "name": "drizzle-cube-help-site-starlight",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run sync:external && astro dev",
    "start": "astro dev",
    "build": "npm run sync:external && astro build && vite build --config vite.config.worker.ts",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "sync:external": "node scripts/sync-external-content.js",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.35.2",
    "astro": "^5.6.1",
    "mermaid": "^11.10.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "vite": "^5.4.1",
    "wrangler": "^4.32.0"
  }
}
