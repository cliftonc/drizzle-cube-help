    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "sync:external": "node scripts/sync-external-content.js",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.35.2",
    "@nivo/heatmap": "^0.99.0",
    "astro": "^5.6.1",
    "d3": "^7.9.0",
    "drizzle-cube": "^0.4.35",
    "mermaid": "^11.10.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-grid-layout": "^2.1.1",
    "react-is": "^19.2.3",
    "recharts": "^3.5.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "pagefind": "^1.4.0",
    "vite": "^5.4.1",
    "wrangler": "^4.32.0"
  }
}
