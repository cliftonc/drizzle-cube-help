{
  "name": "drizzle-cube-help-site-starlight",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run sync:external && astro dev",
    "start": "astro dev",
    "build": "npm run sync:external && astro build && vite build --config vite.config.worker.ts",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "sync:external": "node scripts/sync-external-content.js",
    "astro": "astro",
    "lint": "eslint src/worker.ts src/pages/*.ts src/data/*.ts src/lib/**/*.ts \"src/**/*.test.ts\"",
    "test": "vitest run",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.35.2",
    "@nivo/heatmap": "^0.99.0",
    "astro": "^5.6.1",
    "d3": "^7.9.0",
    "drizzle-cube": "^0.6.4",
    "mermaid": "^11.10.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-grid-layout": "^2.1.1",
    "react-is": "^19.2.3",
    "recharts": "^3.5.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "pagefind": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.32.0"
  }
}
