---
export interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
}

const { src, alt, class: className = '', width, height } = Astro.props;
---

<div class={`lightbox-trigger ${className}`}>
  <img 
    src={src} 
    alt={alt} 
    width={width} 
    height={height}
    loading="lazy"
  />
</div>

<style>
  .lightbox-trigger {
    cursor: pointer !important;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .lightbox-trigger img {
    cursor: pointer !important;
  }
  
  .lightbox-trigger:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }
  
  .lightbox-trigger img {
    transition: opacity 0.2s ease;
  }
  
  .lightbox-trigger:hover img {
    opacity: 0.9;
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', function() {
    // Create lightbox overlay
    const lightboxOverlay = document.createElement('div');
    lightboxOverlay.id = 'lightbox-overlay';
    lightboxOverlay.innerHTML = `
      <div class="lightbox-content">
        <div class="lightbox-header">
          <h3 id="lightbox-title"></h3>
        </div>
        <img id="lightbox-image" src="" alt="" />
        <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
        <button class="lightbox-nav lightbox-prev" aria-label="Previous image">‹</button>
        <button class="lightbox-nav lightbox-next" aria-label="Next image">›</button>
        <div class="lightbox-counter">
          <span id="lightbox-current">1</span> / <span id="lightbox-total">5</span>
        </div>
      </div>
    `;
    document.body.appendChild(lightboxOverlay);

    // Add CSS for lightbox
    const style = document.createElement('style');
    style.textContent = `
      #lightbox-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.9);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        backdrop-filter: blur(5px);
      }
      
      .lightbox-content {
        position: relative;
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding-top: 80px;
        box-sizing: border-box;
      }
      
      #lightbox-image {
        width: auto !important;
        height: auto !important;
        max-width: 90vw !important;
        max-height: calc(90vh - 120px) !important;
        min-width: auto !important;
        min-height: auto !important;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        display: block;
        flex-shrink: 0;
      }
      
      .lightbox-close {
        position: absolute;
        top: -40px;
        right: -10px;
        background: none;
        border: none;
        color: white;
        font-size: 40px;
        cursor: pointer;
        line-height: 1;
        padding: 0;
        width: 40px;
        height: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
        transition: background-color 0.2s ease;
      }
      
      .lightbox-close:hover {
        background-color: rgba(255, 255, 255, 0.1);
      }
      
      .lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.5);
        border: none;
        color: white;
        font-size: 30px;
        cursor: pointer;
        padding: 20px 15px;
        border-radius: 4px;
        transition: background-color 0.2s ease;
        user-select: none;
      }
      
      .lightbox-prev {
        left: 20px;
      }
      
      .lightbox-next {
        right: 20px;
      }
      
      .lightbox-nav:hover {
        background-color: rgba(0, 0, 0, 0.7);
      }
      
      .lightbox-nav:disabled {
        opacity: 0.3;
        cursor: not-allowed;
      }
      
      .lightbox-counter {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        color: white;
        background: rgba(0, 0, 0, 0.5);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
      }
      
      .lightbox-header {
        position: fixed;
        top: 40px;
        left: 50%;
        transform: translateX(-50%);
        color: white;
        background: rgba(0, 0, 0, 0.7);
        padding: 16px 32px;
        border-radius: 8px;
        max-width: 85vw;
        text-align: center;
        z-index: 10;
      }
      
      .lightbox-header h3 {
        margin: 0;
        font-size: 22px;
        font-weight: 600;
        line-height: 1.4;
      }
    `;
    document.head.appendChild(style);

    // Gallery state
    let currentImageIndex = 0;
    let galleryImages = [];
    
    // Collect all lightbox images
    function updateGalleryImages() {
      galleryImages = [];
      document.querySelectorAll('.lightbox-trigger').forEach(trigger => {
        const img = trigger.tagName === 'IMG' ? trigger : trigger.querySelector('img');
        if (img && img.src && img.alt !== 'hidden' && img.alt !== '' && !img.src.includes('data:image/svg+xml')) {
          galleryImages.push({
            src: img.getAttribute('data-src') || img.src,
            alt: img.alt
          });
        }
      });
      document.getElementById('lightbox-total').textContent = galleryImages.length;
    }
    
    // Show image at specific index
    function showImage(index) {
      if (index < 0 || index >= galleryImages.length) return;
      
      currentImageIndex = index;
      const lightboxImg = document.getElementById('lightbox-image');
      const currentCounter = document.getElementById('lightbox-current');
      const lightboxTitle = document.getElementById('lightbox-title');
      
      // Reset any size constraints
      lightboxImg.style.width = 'auto';
      lightboxImg.style.height = 'auto';
      lightboxImg.style.maxWidth = '90vw';
      lightboxImg.style.maxHeight = '90vh';
      
      lightboxImg.src = galleryImages[index].src;
      lightboxImg.alt = galleryImages[index].alt;
      currentCounter.textContent = index + 1;
      
      // Set the title from alt text (split on ' - ' to get title and description)
      const altText = galleryImages[index].alt;
      lightboxTitle.textContent = altText;
      
      // Update navigation button states
      document.querySelector('.lightbox-prev').disabled = index === 0;
      document.querySelector('.lightbox-next').disabled = index === galleryImages.length - 1;
    }

    // Add click handlers to all lightbox triggers
    function addLightboxHandlers() {
      updateGalleryImages();
      
      let actualIndex = 0;
      document.querySelectorAll('.lightbox-trigger').forEach((trigger) => {
        if (trigger.dataset.lightboxInit) return; // Already initialized
        trigger.dataset.lightboxInit = 'true';
        
        const img = trigger.tagName === 'IMG' ? trigger : trigger.querySelector('img');
        if (img && img.src && img.alt !== 'hidden' && img.alt !== '' && !img.src.includes('data:image/svg+xml')) {
          const currentActualIndex = actualIndex;
          trigger.addEventListener('click', function() {
            currentImageIndex = currentActualIndex;
            showImage(currentActualIndex);
            lightboxOverlay.style.display = 'flex';
            document.body.style.overflow = 'hidden';
          });
          actualIndex++;
        }
      });
    }

    // Close lightbox handlers
    function closeLightbox() {
      lightboxOverlay.style.display = 'none';
      document.body.style.overflow = '';
    }

    lightboxOverlay.addEventListener('click', function(e) {
      if (e.target === lightboxOverlay) {
        closeLightbox();
      }
    });

    document.querySelector('.lightbox-close').addEventListener('click', closeLightbox);

    // Navigation button handlers
    document.querySelector('.lightbox-prev').addEventListener('click', function() {
      if (currentImageIndex > 0) {
        showImage(currentImageIndex - 1);
      }
    });

    document.querySelector('.lightbox-next').addEventListener('click', function() {
      if (currentImageIndex < galleryImages.length - 1) {
        showImage(currentImageIndex + 1);
      }
    });

    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
      if (lightboxOverlay.style.display === 'flex') {
        switch(e.key) {
          case 'Escape':
            closeLightbox();
            break;
          case 'ArrowLeft':
            if (currentImageIndex > 0) {
              showImage(currentImageIndex - 1);
            }
            break;
          case 'ArrowRight':
            if (currentImageIndex < galleryImages.length - 1) {
              showImage(currentImageIndex + 1);
            }
            break;
        }
      }
    });

    // Initialize lightbox for existing elements
    addLightboxHandlers();
  });
</script>